{
    "name": "alpha-australia/alpha-ortto-integration",
    "description": "Gravity Forms feed add-on that sends submissions to Ortto.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "compat": "phpcs -p includes alpha-ortto-integration.php --standard=PHPCompatibilityWP --runtime-set testVersion 8.2-"
    }
}
